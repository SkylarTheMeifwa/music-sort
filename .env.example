# ── Required ──────────────────────────────────────────────────────────────────
# Your Spotify app's Client ID (from https://developer.spotify.com/dashboard)
VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id_here

# ── Optional ──────────────────────────────────────────────────────────────────
# Override the OAuth redirect URI (defaults to current origin + base URL).
# NOTE: Spotify forbids 'localhost' — use 127.0.0.1 for local dev.
# VITE_SPOTIFY_REDIRECT_URI=http://127.0.0.1:5173/

# Set to your GitHub Pages sub-path when building for GitHub Pages deployment.
# Leave blank (or '/') for Vercel / root-domain hosting.
# VITE_BASE_PATH=/music-sort/
